# Forensic Economic Calculator — environment variables.
# Copy to .env for local use (loaded by your shell, e.g. `set -a; . ./.env; set +a`)
# or set these as Railway service Variables. NEVER commit a real .env or secrets.

# --- session / cookies ------------------------------------------------------
# Long random string that signs the session cookie. Generate, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string
# Send the session cookie only over HTTPS. true in production (Railway), false local.
COOKIE_SECURE=true

# --- persistence ------------------------------------------------------------
# On Railway, mount a Volume at /data and point the DB at it so saved cases
# survive redeploys. Locally this can be a relative path.
DB_PATH=/data/forensic_calc.sqlite

# --- auth (single-user Google OAuth) ----------------------------------------
# From Google Cloud Console > Credentials > OAuth 2.0 Client (Web application).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated allow-list of emails permitted to sign in.
ALLOWED_EMAILS=christophertskerritt@gmail.com
# Local-only escape hatch: bypass Google sign-in and act as DEV_USER_EMAIL.
# Do NOT set this in production.
AUTH_DISABLED=false
DEV_USER_EMAIL=christophertskerritt@gmail.com

# --- LCP growth-rate helper (FRED) ------------------------------------------
# St. Louis Fed FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html).
# Required for /lookups/lcp-growth; never commit the real key.
FRED_API_KEY=

# --- PDF report branding ----------------------------------------------------
REPORT_FIRM=KW Economics
REPORT_AUTHOR=Christopher T. Skerritt, M.Ed., CRC, CLCP
